# ── WhatsApp (Meta Developer Portal) ─────────────────────
# Choose any secret word — enter this SAME word in Meta Portal
VERIFY_TOKEN=my_secret_verify_token

# Meta Portal → WhatsApp → API Setup → Temporary access token
WA_TOKEN=

# Meta Portal → WhatsApp → API Setup → Phone number ID
PHONE_ID=

# Meta Portal → App Settings → Basic → App Secret (optional)
APP_SECRET=

# ── Groq AI (console.groq.com) ────────────────────────────
# Get free key at: console.groq.com → API Keys → Create new
GROQ_API_KEY=

# Model choice — pick one:
# llama3-8b-8192       (fast, good for chat)
# llama3-70b-8192      (smarter, slower)
# mixtral-8x7b-32768   (good for long context)
# gemma2-9b-it         (fast, concise)
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ngrok (ngrok.com) ─────────────────────────────────────
# Free account at ngrok.com → Your Authtoken
# Without this ngrok still works but shows a browser warning page
NGROK_TOKEN=